# LLM Provider: "cortex" (Snowflake Cortex AI, default) or "ollama" (local)
LLM_PROVIDER=cortex

# Model name (depends on provider)
# Cortex options: llama3.1-70b, llama3.1-8b, mistral-large2
# Ollama options: llama3.1:8b, llama3.1:70b, codellama:13b, etc.
LLM_MODEL=llama3.1-70b

# Ollama settings (only needed when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Snowflake connection (uses ~/.snowflake/connections.toml by default)
# SNOWFLAKE_CONNECTION_NAME=your-connection-name

# Postgres (defaults match docker-compose.yml)
PGHOST=localhost
PGPORT=5432
PGDATABASE=demo
PGUSER=demo
PGPASSWORD=demo
